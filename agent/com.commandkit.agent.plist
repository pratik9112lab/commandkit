<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.commandkit.agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/commandkit-agent</string>
        <string>--server</string>
        <string>COMMANDKIT_SERVER_URL</string>
        <string>--token</string>
        <string>COMMANDKIT_ENROLLMENT_TOKEN</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/var/log/commandkit/agent.log</string>

    <key>StandardErrorPath</key>
    <string>/var/log/commandkit/agent_error.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>SoftResourceLimits</key>
    <dict>
        <key>NumberOfFiles</key>
        <integer>1024</integer>
    </dict>

    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
